@page "/apodshort"
@model SpaceFlight_News_App.Pages.ApodShortModel

@using SpaceFlight_News_App.Models;
@using Microsoft.EntityFrameworkCore;
@using SpaceFlight_News_App.Data;
@using System.Diagnostics
@{
#if DEBUG
}
<PageTitle>Astronomy Picture of the Day</PageTitle>

@if (Model.apod == null)
{
    <p><em>@Model.Message</em></p>
}
else{
    <!-- Today APOD card-->
    <aside id="nasa__apod" class="nasa__card">
    @if (Model.apod.media == "video")
    {
        <iframe class="iframeSm" controls
        src="@Model.apod.hdurl" allowfullscreen>
        </iframe>
    }                
    else {
        <img class="apiHDimg2" src="@Model.apod.hdurl" alt="image_empty">
    }
    <h2 id="apiTitle">@Model.apod.apodtitle</h2>
    <h3 id="API">Astonomy&nbsp;Picture of&nbsp;the&nbsp;Day</h3>
    <h4 id="apiDate">@Model.apod.date</h4>
        <div>
            <a href="apoddetailsdisp" class="btn btn--secondary">View</a>
            <a href="apodranddisp" class="btn btn--secondary">Random</a>
        </div>
    </aside><!-- Today APOD card end-->
}

@{
}
@{
#endif
}