@* // ==============================================================================
// Filename: Articles.cshtml
//
// Author: Robert Howell
// Date: 6/25/2024
// Edited: 7/20/2024
// Version: 1.3
//
// Description: This page displays articles.
//  --6/29 - Added table view + toggle button
//  --7/20 - Added date browse buttons
//
// ==============================================================================
 *@
@page "/articles"
@model SpaceFlight_News_App.Pages.ArticlesModel

@using SpaceFlight_News_App.Models;
@using Microsoft.EntityFrameworkCore;
@using SpaceFlight_News_App.Data;

@{
    ViewData["Title"] = "Articles";
}

@* Settings Bar*@
<nav id="art_display">
    <hr />
    <h3>Display</h3>
    <div class="navList">
     @* /Articles?view=grid *@
        <form asp-page="/Articles" method="get" accept-charset="UTF-8">
            <button value="grid" name="view" type="submit" class="btn-view @Model.GridActive" title="Grid">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-layout-text-sidebar-reverse" viewBox="0 0 16 16">
                    <path d="M12.5 3a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1zm0 3a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1zm.5 3.5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 .5-.5m-.5 2.5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1z" />
                    <path d="M16 2a2 2 0 0 0-2-2H2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2zM4 1v14H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zm1 0h9a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5z" />
                </svg>
            </button>
          @* /Articles?view=grid-sm *@
            <button value="grid-sm" name="view" type="submit" class="btn-view grid-view-sm @Model.GridSmActive" title="Grid Small">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-grid" viewBox="0 0 16 16">
                    <path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5zM2.5 2a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5zm6.5.5A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5zM1 10.5A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5zm6.5.5A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5z" />
                </svg>
            </button>
          @* /Articles?view=table *@
            <button value="table" name="view" type="submit" class="btn-view @Model.TableActive" title="Table">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-table" viewBox="0 0 16 16">
                    <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm15 2h-4v3h4zm0 4h-4v3h4zm0 4h-4v3h3a1 1 0 0 0 1-1zm-5 3v-3H6v3zm-5 0v-3H1v2a1 1 0 0 0 1 1zm-4-4h4V8H1zm0-4h4V4H1zm5-3v3h4V4zm4 4H6v3h4z" />
                </svg>
            </button>
            @if (Model.ArticleDate != null)
            {
                <input type="hidden" name="SetDate" value="@Model.ArticleDate" />
            }
            @if (Model.NewsSiteQP != null)
            {
                <input type="hidden" name="newsSite" value="@Model.NewsSiteQP" />
            }
        </form>
    </div>
    <hr />
    @* Previous + Next date selectors LEADING *@
    @if (Model.NewsSiteQP == null)
    {
        <div id="DateSelectLeading">
            @* Data Date Selecting *@
            @{
                Model.GetPreviousArticleDate();
                Model.GetNextArticleDate();
                Model.GetNextWeekArticleDate();
                Model.GetPreviousWeekArticleDate();
                await Model.GetOldestArticleDate();
            }
            <form asp-page="/Articles" method="get" class="change_date_select" accept-charset="UTF-8">
              @* Previous Buttons *@
                @if (DateTime.Parse(Model.PreviousArticleDate!) >= DateTime.Parse(Model.OldestArticleDate!))
                {
                    <button value="@Model.OldestArticleDate" name="SetDate" type="submit" title="Oldest">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-left" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M8.354 1.646a.5.5 0 0 1 0 .708L2.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                            <path fill-rule="evenodd" d="M12.354 1.646a.5.5 0 0 1 0 .708L6.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                        </svg>
                    </button>
                }
                @if (DateTime.Parse(Model.PreviousWeekArticleDate!) >= DateTime.Parse(Model.OldestArticleDate!))
                {
                    <button value="@Model.PreviousWeekArticleDate" name="SetDate" type="submit" title="Previous Week">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8" />
                        </svg>
                    </button>
                }
                @if (DateTime.Parse(Model.PreviousArticleDate!) >= DateTime.Parse(Model.OldestArticleDate!))
                {
                    <button value="@Model.PreviousArticleDate" name="SetDate" type="submit" title="Previous Day">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left-short" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5" />
                        </svg>
                    </button>
                }
                @if (Request.Query.ContainsKey("view") && Request.Query["view"] != "")
                {
                    <input type="hidden" name="view" value="@Request.Query["view"]" />
                }
            <span>@Model.ArticleDate</span>
              @* Next Buttons *@
                @if (DateTime.Parse(Model.NextArticleDate!) < DateTime.Now)
                {
                    <button value="@Model.NextArticleDate" name="SetDate" type="submit" title="Next Day">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right-short" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8" />
                        </svg>
                    </button>
                    @if (DateTime.Parse(Model.NextWeekArticleDate!) <= DateTime.Now)
                    {
                        <button value="@Model.NextWeekArticleDate" name="SetDate" type="submit" title="Next Week">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8" />
                            </svg>
                        </button>
                    }
                    <button value="@DateTime.Now.ToShortDateString()" name="SetDate" type="submit" title="Newest (today)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-right" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M3.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L9.293 8 3.646 2.354a.5.5 0 0 1 0-.708" />
                            <path fill-rule="evenodd" d="M7.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L13.293 8 7.646 2.354a.5.5 0 0 1 0-.708" />
                        </svg>
                    </button>
                }
            </form>
        </div>
    }
    @* Previous + Next date selectors LEADING END *@

</nav>
<section class="container">
    @* Search Bar *@
    <div id="SearchBar">
        <form method="get" class="form-group d-inline-block" asp-page="/Articles" accept-charset="UTF-8">
            <div>
                <label for="search">Search &lpar;NewsSites&rpar;:</label>
                <input name="newsSite" type="text" class="form-control" id="search" placeholder="News sites" pattern="^[A-Za-z0-9 .]{0,48}" title="Accepted inputs: [a-z], [A-Z], [0-9 .]">
            </div>
            <div>
                <input type="submit" value="Submit" />
                <input type="reset" value="Clear" />
            </div>
            @if (Request.Query["view"] != "" && Request.Query["view"].Count >= 0)
            {
                <input type="hidden" name="view" value="@Request.Query["view"]" />
            }
        </form><br/>
        <a class="navbar-brand" href="/About#ArticlesSearch" title="About">About</a>
    </div>
</section>

@* Articles Start *@
<section id="art_container" class="container mb-3">
@if (Model.articles == null || !Model.articles.Any())
{
    @* No data to display *@
    <style>
        main {
            background: var(--secondary1);
        }
    </style>
    <p><em>@Model.Message</em></p>
}
else{
    @if (Model.ViewQP == "table")
    {
        @* Display a table format *@
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>News Site</th>
                    <th>Title/Hyperlink</th>
                    <th>Summary</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var service in Model.articles)
                {
                    <tr class="article">
                        <td>@service.newsSite</td>
                        <td class="art_header"><a href="@service.url" target="_blank" class="link--primary" rel="nofollow">@service.title</a></td>
                        <td>@service.summary</td>
                        <td>@service.date</td>
                    </tr>
                }
            </tbody>
            </table>
        }
        @* else *@
        @* { *@
        @*     $1$ Display articles as cards #1# *@
        @*     <article id="art-container" class="text-center @Request.Query["view"]"> *@
        @*     @foreach (var service in Model.articles) *@
        @*     { *@
        @*         <article class="art_grid_container row"> *@
        @*             <img class="art_picture col" src="@service.textURL" alt="Article Picture"> *@
        @*             <h3 class="art_header col"><a href="@service.url" target="_blank" class="link--primary" rel="nofollow">@service.title</a></h3> *@
        @*             <div class="art_descrip col"> *@
        @*                 @service.summary<br><br> *@
        @*                 <div class="art_foot"><span>@service.newsSite</span><span class="art_date">@service.date</span></div> *@
        @*             </div> *@
        @*         </article> *@
        @*     } *@
        @*     </article> *@
        @* } *@
    else
    {
        @* Display articles as cards *@
        <section id="articles" class="@Request.Query["view"]">
            @foreach (var service in Model.articles)
            {
                <article class="article-card art-grid-container row">
                    <img class="art_picture col" src="@service.textURL" alt="Article Picture">
                    <h3 class="art_header col">
                        <a href="@service.url" target="_blank" class="link--primary" rel="nofollow">@service.title</a>
                    </h3>
                    <div class="art_descrip col">
                        @service.summary<br><br>
                        <div class="art_foot">
                            <span>@service.newsSite</span>
                            <span class="art_date">@service.date</span>
                        </div>
                    </div>
                </article>
            }
        </section>
    }
    @* Previous + Next date selectors *@
    @if(Model.NewsSiteQP == null)
    {
        <div id="DateSelectTrailing">
            @* Data Date Selecting *@
            @{
                Model.GetPreviousArticleDate();
                Model.GetNextArticleDate();
                Model.GetNextWeekArticleDate();
                Model.GetPreviousWeekArticleDate();
                await Model.GetOldestArticleDate();
            }
            <form asp-page="/Articles" method="get" class="change_date_select" accept-charset="UTF-8">
              @* Previous Buttons *@
                @if (DateTime.Parse(Model.PreviousArticleDate!) >= DateTime.Parse(Model.OldestArticleDate!))
                {
                    <button value="@Model.OldestArticleDate" name="SetDate" type="submit" title="Oldest">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-left" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M8.354 1.646a.5.5 0 0 1 0 .708L2.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                            <path fill-rule="evenodd" d="M12.354 1.646a.5.5 0 0 1 0 .708L6.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                        </svg>
                    </button>
                }
                @if (DateTime.Parse(Model.PreviousWeekArticleDate!) >= DateTime.Parse(Model.OldestArticleDate!))
                {
                    <button value="@Model.PreviousWeekArticleDate" name="SetDate" type="submit" title="Previous Week">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8" />
                        </svg>
                    </button>
                }
                @if (DateTime.Parse(Model.PreviousArticleDate!) >= DateTime.Parse(Model.OldestArticleDate!))
                {
                    <button value="@Model.PreviousArticleDate" name="SetDate" type="submit" title="Previous Day">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left-short" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5" />
                        </svg>
                    </button>
                }
                @if (Request.Query.ContainsKey("view") && Request.Query["view"] != "")
                {
                    <input type="hidden" name="view" value="@Request.Query["view"]" />
                }
            <span>@Model.ArticleDate</span>
              @* Next Buttons *@
                @if (DateTime.Parse(Model.NextArticleDate!) < DateTime.Now)
                {
                    <button value="@Model.NextArticleDate" name="SetDate" type="submit" title="Next Day">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right-short" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8" />
                        </svg>
                    </button>
                    @if (DateTime.Parse(Model.NextWeekArticleDate!) <= DateTime.Now)
                    {
                        <button value="@Model.NextWeekArticleDate" name="SetDate" type="submit" title="Next Week">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8" />
                            </svg>
                        </button>
                    }
                    <button value="@DateTime.Now.ToShortDateString()" name="SetDate" type="submit" title="Newest (today)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-right" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M3.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L9.293 8 3.646 2.354a.5.5 0 0 1 0-.708" />
                            <path fill-rule="evenodd" d="M7.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L13.293 8 7.646 2.354a.5.5 0 0 1 0-.708" />
                        </svg>
                    </button>
                }
            </form>
        </div>
    }
}
</section>


@{
    
}
