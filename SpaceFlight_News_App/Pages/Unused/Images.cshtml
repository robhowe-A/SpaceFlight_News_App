@page "/images"
@model SpaceFlight_News_App.Pages.ImagesModel

@{
    ViewData["Title"] = "About";

#if DEBUG
}
@if (Model.images == null || !Model.images.Any())
{
    <style>
        main {
            background: var(--secondary1);
        }
    </style>
    <p><em>@Model.Message</em></p>
}
else{
    @* Display articles as cards *@
    int pictureCount = 0;
        @for (int i = 0; i < Model.images.Length / 5; i++)
        {
            <div class="row">
                @for (int col = 0; col < 3; col++)
                {
                    <div id="col-sm-6" style="width:220px; height:220px;">
                        <div class="card">
                            <div class="card-body">
                            <img src="@Model.images[pictureCount].textURL" alt="@Model.images[pictureCount].title" width="100" height="100">
                            <p class="card-text">@Model.images[pictureCount].date</p>
                            </div>
                        </div>
                    </div>
                pictureCount++;
                }
            </div>
            pictureCount++;
        }
}
@{
}
@{
#endif
}